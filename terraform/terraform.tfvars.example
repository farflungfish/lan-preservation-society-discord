# NOTE: The Discord bot token is NOT set here.
# The Lucky3028/discord provider reads it automatically from the
# DISCORD_TOKEN environment variable.
#
# For local development, export the variable before running Terraform:
#   export DISCORD_TOKEN="your-discord-bot-token-here"
#
# In HCP Terraform, set DISCORD_TOKEN as a sensitive environment variable
# in the workspace settings (not as a Terraform variable).
